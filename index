<!DOCTYPE html>
<html lang="ko">

<head>

<meta charset="UTF-8">

<title>Surf Type Test</title>

<link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@300;500;700&display=swap" rel="stylesheet">

<style>

body{
font-family:'Pretendard',sans-serif;
margin:0;
height:100vh;

background:
radial-gradient(circle at 20% 20%,rgba(255,255,255,0.15),transparent),
radial-gradient(circle at 80% 60%,rgba(255,255,255,0.15),transparent),
linear-gradient(135deg,#2c9cff,#46e3c4);

display:flex;
justify-content:center;
align-items:center;

}

.container{

width:420px;
background:white;
border-radius:20px;
padding:40px;
box-shadow:0 20px 40px rgba(0,0,0,0.2);

text-align:center;

}

h1{
margin-bottom:10px;
}

button{

background:#1f8fff;
border:none;
padding:12px 26px;
border-radius:12px;
color:white;
font-size:16px;
cursor:pointer;
margin-top:20px;

}

.answer{

background:#f1f6ff;
margin:10px 0;
padding:12px;
border-radius:10px;
cursor:pointer;

}

.answer:hover{

background:#dde9ff;

}

img{

width:200px;
margin-top:10px;
border-radius:10px;

}

</style>

</head>

<body>

<div class="container">

<div id="start">

<h1>🏄 나는 어떤 서퍼일까?</h1>

<p>
파도를 대하는 나의 스타일을 알아보자
</p>

<button onclick="startTest()">테스트 시작</button>

</div>

<div id="quiz" style="display:none">

<h3 id="progress"></h3>

<h2 id="question"></h2>

<div id="answers"></div>

</div>

<div id="result" style="display:none">

<h2 id="resultTitle"></h2>

<img id="resultImg">

<p id="resultDesc"></p>

<button onclick="apply()">동아리 신청하기</button>

</div>

</div>

<script>

let current=0

let score={wave:0,free:0,vibe:0,soul:0}

const questions=[

{
q:"여행 스타일은?",
a:[
{text:"계획 세우기",type:"wave"},
{text:"즉흥 여행",type:"free"},
{text:"친구랑 여행",type:"vibe"},
{text:"풍경 감상",type:"soul"}
]
},

{
q:"동아리에서 나는?",
a:[
{text:"실력 성장",type:"wave"},
{text:"새로운 경험",type:"free"},
{text:"사람들과 친해짐",type:"vibe"},
{text:"힐링",type:"soul"}
]
},

{
q:"파도를 보면?",
a:[
{text:"타이밍 계산",type:"wave"},
{text:"일단 뛰어듦",type:"free"},
{text:"친구 부름",type:"vibe"},
{text:"풍경 감상",type:"soul"}
]
},

{
q:"나의 성격은?",
a:[
{text:"목표지향",type:"wave"},
{text:"도전적",type:"free"},
{text:"사교적",type:"vibe"},
{text:"감성적",type:"soul"}
]
},

{
q:"휴일에 나는?",
a:[
{text:"운동",type:"wave"},
{text:"새로운 활동",type:"free"},
{text:"친구 만나기",type:"vibe"},
{text:"산책",type:"soul"}
]
},

{
q:"바다에서 최고의 순간은?",
a:[
{text:"파도 성공",type:"wave"},
{text:"새 기술 도전",type:"free"},
{text:"같이 웃는 순간",type:"vibe"},
{text:"노을",type:"soul"}
]
},

{
q:"내가 좋아하는 분위기는?",
a:[
{text:"열정적인",type:"wave"},
{text:"자유로운",type:"free"},
{text:"활기찬",type:"vibe"},
{text:"차분한",type:"soul"}
]
},

{
q:"서핑을 한다면?",
a:[
{text:"실력 향상",type:"wave"},
{text:"도전",type:"free"},
{text:"사람들과 재미",type:"vibe"},
{text:"바다 감성",type:"soul"}
]
}

]

const results={

wave:{
title:"🌊 Wave Rider",
img:"wave.png",
desc:"목표를 세우면 끝까지 도전하는 타입. 파도를 읽는 능력과 집중력이 뛰어나며 성장형 서퍼 스타일."
},

free:{
title:"🏄 Free Surfer",
img:"free.png",
desc:"자유롭고 도전적인 성향. 새로운 경험을 즐기며 바다와 함께 모험을 즐기는 스타일."
},

vibe:{
title:"🎉 Beach Vibe Maker",
img:"vibe.png",
desc:"사람들과 함께할 때 가장 빛나는 타입. 동아리 분위기를 책임지는 핵심 멤버."
},

soul:{
title:"🌅 Ocean Soul",
img:"soul.png",
desc:"바다 감성을 사랑하는 힐링형 서퍼. 자연과 분위기를 즐기며 서핑을 하는 타입."
}

}

function startTest(){

document.getElementById("start").style.display="none"
document.getElementById("quiz").style.display="block"

showQuestion()

}

function showQuestion(){

let q=questions[current]

document.getElementById("progress").innerText=(current+1)+" / "+questions.length

document.getElementById("question").innerText=q.q

let html=""

q.a.forEach(a=>{

html+=`<div class="answer" onclick="select('${a.type}')">${a.text}</div>`

})

document.getElementById("answers").innerHTML=html

}

function select(type){

score[type]++

current++

if(current<questions.length){

showQuestion()

}else{

showResult()

}

}

function showResult(){

document.getElementById("quiz").style.display="none"
document.getElementById("result").style.display="block"

let max=Object.keys(score).reduce((a,b)=>score[a]>score[b]?a:b)

document.getElementById("resultTitle").innerText=results[max].title
document.getElementById("resultDesc").innerText=results[max].desc
document.getElementById("resultImg").src=results[max].img

}

function apply(){

window.open("https://docs.google.com/forms/d/e/1FAIpQLSdUfT1mArajdegkuPpvFVDfW-E7uEoijNLzhviAQCk5fOchiw/viewform")

}

</script>

</body>
</html>
